## Routing & Guards

```jsx
// Route chỉ cần đăng nhập:
<Route element={<PrivateRoute />}>
  <Route path="/profile/:username" element={<ProfilePage />} />
</Route>

// Route chỉ Premium:
<Route element={<PremiumRoute />}>
  <Route path="/exams/:id/do" element={<ExamDoPage />} />
</Route>

// Route chỉ Admin:
<Route element={<AdminRoute />}>
  <Route path="/admin/*" element={<AdminLayout />} />
</Route>
```

Không tự viết logic check role trong từng page — luôn dùng guard.

---

## Xử lý Loading & Error

Mọi page fetch dữ liệu phải xử lý đủ 3 trạng thái:

```jsx
import styles from "./FeedPage.module.css";

function FeedPage() {
  const { posts, isLoading, error } = useSelector((state) => state.feed);

  if (isLoading) return <Spinner />;
  if (error) return <p className={styles.error}>{error}</p>;
  if (posts.length === 0) return <EmptyState message="Chưa có bài viết nào" />;

  return (
    <div className={styles.list}>
      {posts.map((post) => (
        <PostCard key={post.id} post={post} />
      ))}
    </div>
  );
}
```


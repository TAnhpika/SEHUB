## Icon — Font Awesome 6

Luôn dùng Font Awesome cho icon, không dùng emoji hay ký tự đặc biệt:

```jsx
import { FontAwesomeIcon } from '@fortawesome/react-fontawesome';
import { faHeart, faComment, faTrash } from '@fortawesome/free-solid-svg-icons';
import { faHeart as faHeartRegular } from '@fortawesome/free-regular-svg-icons';

// Icon trong button:
<button className={styles['like-btn']}>
  <FontAwesomeIcon icon={faHeart} />
  Like
</button>

// Icon đứng một mình:
<FontAwesomeIcon icon={faTrash} className={styles['delete-icon']} />
```

- Chỉ import đúng icon cần dùng — không import `{ library }` toàn bộ
- Solid (`free-solid-svg-icons`): action, trạng thái đang active
- Regular (`free-regular-svg-icons`): trạng thái chưa active (tim rỗng, bookmark rỗng...)

---

## Ảnh — src/img/

- Ảnh tĩnh (logo, default avatar, banner...) đặt trong `src/img/`
- Ảnh từ API (avatar user, ảnh upload...) dùng URL từ response — không đặt trong `img/`

```jsx
import logo from '../../img/logo.png';
import defaultAvatar from '../../img/default-avatar.png';

<img src={logo} alt="SEHUB Logo" className={styles.logo} />

// Ảnh từ API:
<img src={user.avatarUrl || defaultAvatar} alt={user.name} className={styles.avatar} />
```

---

```js
// src/features/feed/feedSlice.js
import { createSlice } from "@reduxjs/toolkit";
import { fetchPosts } from "./feedThunks";

const initialState = {
  posts: [],
  currentPost: null,
  isLoading: false,
  error: null,
};

const feedSlice = createSlice({
  name: "feed",
  initialState,
  reducers: {
    clearError: (state) => {
      state.error = null;
    },
  },
  extraReducers: (builder) => {
    builder
      .addCase(fetchPosts.pending, (state) => {
        state.isLoading = true;
        state.error = null;
      })
      .addCase(fetchPosts.fulfilled, (state, action) => {
        state.isLoading = false;
        state.posts = action.payload;
      })
      .addCase(fetchPosts.rejected, (state, action) => {
        state.isLoading = false;
        state.error = action.payload;
      });
  },
});

export const { clearError } = feedSlice.actions;
export default feedSlice.reducer;
```

---

## Cách viết Thunk

```js
// src/features/feed/feedThunks.js
import { createAsyncThunk } from "@reduxjs/toolkit";
import { getPostsAPI } from "./feedService";

export const fetchPosts = createAsyncThunk(
  "feed/fetchPosts",
  async (params, { rejectWithValue }) => {
    try {
      const response = await getPostsAPI(params);
      return response.data;
    } catch (error) {
      return rejectWithValue(error.response?.data?.message || "Có lỗi xảy ra");
    }
  },
);
```

---

## Cách viết Service

```js
// src/features/feed/feedService.js
import axiosInstance from "../../services/axiosInstance";

export const getPostsAPI = (params) => axiosInstance.get("/posts", { params });
export const createPostAPI = (data) => axiosInstance.post("/posts", data);
export const updatePostAPI = (id, data) =>
  axiosInstance.put(`/posts/${id}`, data);
export const deletePostAPI = (id) => axiosInstance.delete(`/posts/${id}`);
```


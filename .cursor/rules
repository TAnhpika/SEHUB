import useAuth from "../../hooks/useAuth";

function ExamDetailPage() {
  const { isPremium, isAdmin } = useAuth();

  return (
    <div className={styles.page}>
      <QuestionList />
      {(isPremium || isAdmin) && <AnswerSection />}
    </div>
  );
}

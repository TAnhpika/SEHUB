{
  "ConnectionStrings": {
    "DefaultConnection": "Server=(localdb)\\mssqllocaldb;Database=SEHubDb;Trusted_Connection=True;MultipleActiveResultSets=true;TrustServerCertificate=True"
  },
  "Jwt": {
    "Secret": "SEHub-Dev-Secret-Key-Min-32-Chars-Long!",
    "Issuer": "SEHub",
    "Audience": "SEHub.Client",
    "ExpirationMinutes": 60,
    "RefreshExpirationDays": 7
  },
  "Frontend": {
    "BaseUrl": "http://localhost:5173"
  },
  "PayOS": {
    "ClientId": "mock-client-id",
    "ApiKey": "mock-api-key",
    "ChecksumKey": "mock-checksum-key-dev",
    "ApiBaseUrl": "https://api-merchant.payos.vn",
    "ReturnUrl": "http://localhost:5173/home/premium/payment-return?orderId={orderId}",
    "CancelUrl": "http://localhost:5173/home/premium?cancelled=1"
  },
  "FileStorage": {
    "Provider": "Local",
    "LocalPath": "wwwroot/uploads",
    "LocalRootPath": "wwwroot/uploads",
    "PublicBaseUrl": "/uploads",
    "ApiBaseUrl": "http://localhost:5006"
  },
  "Cors": {
    "AllowedOrigins": [
      "http://localhost:5173",
      "http://localhost:5174",
      "http://localhost:5175"
    ]
  },
  "Ai": {
    "Provider": "Mock",
    "ApiKey": "",
    "Model": "nex-agi/nex-n2-pro:free",
    "BaseUrl": "https://openrouter.ai/api/v1",
    "HttpReferer": "http://localhost:5173",
    "SiteTitle": "SEHub",
    "DailyTokenLimitFree": 10,
    "DailyTokenLimitPremium": 1000,
    "TokenCostExplain": 10,
    "TokenCostChat": 10
  },
  "Email": {
    "Provider": "Logging"
  },
  "Otp": {
    "ResendCooldownSeconds": 60,
    "MaxAttempts": 5,
    "MaxRequestsPerHour": 5,
    "ExpiryMinutes": 10
  },
  "Auth": {
    "RequireConfirmedEmail": false
  },
  "Google": {
    "ClientId": "",
    "ClientSecret": ""
  },
  "GoogleDrive": {
    "ServiceAccountPath": "",
    "FolderId": ""
  },
  "Cloudinary": {
    "CloudName": "",
    "ApiKey": "",
    "ApiSecret": "",
    "Secure": true,
    "AvatarFolder": "sehub/avatars",
    "PostFolder": "sehub/posts",
    "ChatFolder": "sehub/chat"
  },
  "N8n": {
    "Enabled": false,
    "WebhookUrl": "",
    "RefundWebhookUrl": "http://localhost:5678/webhook/premium-refund",
    "WebhookSecret": "",
    "InboundSecretKey": "",
    "TimeoutSeconds": 10
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft.AspNetCore": "Warning",
        "Microsoft.EntityFrameworkCore": "Warning"
      }
    }
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}

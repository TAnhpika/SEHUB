{

  "_comment": "Copy to appsettings.Development.Local.json (gitignored). Fill credentials locally. Never commit real passwords.",

  "Email": {

    "Provider": "Smtp",

    "Smtp": {

      "Host": "smtp.gmail.com",

      "Port": 587,

      "Username": "your-account@gmail.com",

      "Password": "your-16-char-app-password",

      "From": "your-account@gmail.com",

      "FromDisplayName": "SEHub",

      "EnableSsl": true

    }

  },

  "Google": {

    "ClientId": "your-google-oauth-client-id.apps.googleusercontent.com",

    "ClientSecret": "your-google-oauth-client-secret"

  }

}


{
  "info": {
    "name": "SEHub API — FE Integration",
    "description": "SEHub G1 MVP. Base URL dev: http://localhost:5006/api/v1\n\nEnvelope: { success, data, message, errors }\n\nRegister password: min 8 chars, upper + lower + digit + special (e.g. Student@123)\n\nDev admin: admin@sehub.local / Admin@123",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "host", "value": "http://localhost:5006" },
    { "key": "baseUrl", "value": "http://localhost:5006/api/v1" },
    { "key": "accessToken", "value": "" }
  ],
  "item": [
    {
      "name": "Health",
      "item": [
        {
          "name": "GET /health",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{host}}/health"
          }
        }
      ]
    },
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "  var json = pm.response.json();",
                  "  if (json.data && json.data.accessToken) {",
                  "    pm.collectionVariables.set('accessToken', json.data.accessToken);",
                  "  }",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"postman.user@fpt.edu.vn\",\n  \"username\": \"postmanuser\",\n  \"password\": \"Student@123\",\n  \"displayName\": \"Postman User\"\n}"
            },
            "url": "{{baseUrl}}/auth/register"
          }
        },
        {
          "name": "Register — weak password (400)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"weak@fpt.edu.vn\",\n  \"username\": \"weakuser\",\n  \"password\": \"hauvip123\",\n  \"displayName\": \"Weak\"\n}"
            },
            "url": "{{baseUrl}}/auth/register"
          }
        },
        {
          "name": "Login (admin)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var json = pm.response.json();",
                  "if (json.data && json.data.accessToken) {",
                  "  pm.collectionVariables.set('accessToken', json.data.accessToken);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"emailOrUsername\": \"admin@sehub.local\",\n  \"password\": \"Admin@123\"\n}"
            },
            "url": "{{baseUrl}}/auth/login"
          }
        },
        {
          "name": "Me",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": "{{baseUrl}}/auth/me"
          }
        },
        {
          "name": "Logout",
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": "{{baseUrl}}/auth/logout"
          }
        }
      ]
    },
    {
      "name": "Feed",
      "item": [
        {
          "name": "List posts",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/posts?page=1&pageSize=10"
          }
        },
        {
          "name": "Featured posts",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/posts/featured"
          }
        }
      ]
    },
    {
      "name": "Premium",
      "item": [
        {
          "name": "Plans",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/premium/plans"
          }
        }
      ]
    },
    {
      "name": "Profile",
      "item": [
        {
          "name": "My stats",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": "{{baseUrl}}/profiles/me/stats"
          }
        }
      ]
    }
  ]
}
